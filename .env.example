# ─────────────────────────────────────────────────────────────────────────────
# CloudAttend — Environment Variable Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# The .env file is gitignored — never commit real credentials.
# ─────────────────────────────────────────────────────────────────────────────

# Django core
SECRET_KEY=generate-with--python-c-import-secrets-print-secrets.token_urlsafe-50
DEBUG=True
ALLOWED_HOSTS=*

# Database (leave commented out for local SQLite)
#RDS_HOSTNAME=your-rds-endpoint.rds.amazonaws.com
#RDS_PORT=3306
#RDS_DB_NAME=attendance_db
#RDS_USERNAME=attendanceadmin
#RDS_PASSWORD=

# Email — SMTP (leave EMAIL_HOST commented out to use console backend)
#EMAIL_HOST=smtp.gmail.com
#EMAIL_PORT=587
#EMAIL_USE_TLS=True
#EMAIL_HOST_USER=your@gmail.com
#EMAIL_HOST_PASSWORD=your-16-char-app-password
#DEFAULT_FROM_EMAIL=CloudAttend <your@gmail.com>
#ATTENDANCE_ADMIN_EMAILS=admin@school.edu
#SITE_URL=http://localhost:8000
