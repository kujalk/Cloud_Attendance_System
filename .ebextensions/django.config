packages:
  yum:
    python3-devel: []
    mariadb105-devel: []
    libjpeg-turbo-devel: []

option_settings:
  aws:elasticbeanstalk:container:python:
    WSGIPath: Attendance_System.wsgi:application
  aws:elasticbeanstalk:environment:proxy:staticfiles:
    /static: staticfiles
  aws:elasticbeanstalk:application:environment:
    DJANGO_SETTINGS_MODULE: Attendance_System.settings

files:
  "/opt/deploy_setup.py":
    mode: "000755"
    owner: root
    group: root
    content: |
      import os, sys, django

      os.environ.setdefault('DJANGO_SETTINGS_MODULE', 'Attendance_System.settings')
      sys.path.insert(0, '/var/app/staging')
      django.setup()

      from django.db import connection

      # ── 1. Log which database we are connected to ────────────────────────────
      db_host = os.environ.get('RDS_HOSTNAME', '')
      db_name = os.environ.get('RDS_DB_NAME', 'SQLite')
      if db_host:
          print(f'DB_CHECK: using Aurora MySQL | host={db_host} | db={db_name}')
      else:
          print('DB_CHECK: WARNING — RDS_HOSTNAME not set, using SQLite. '
                'Superuser will NOT be in Aurora.')

      # ── 2. Verify DB connection ──────────────────────────────────────────────
      try:
          with connection.cursor() as cur:
              cur.execute('SELECT 1')
          print('DB_CHECK: connection OK')
      except Exception as exc:
          print(f'DB_CHECK: connection FAILED — {exc}')
          sys.exit(1)

      # ── 3. Create superuser ──────────────────────────────────────────────────
      from django.contrib.auth import get_user_model
      U = get_user_model()

      u = os.environ.get('DJANGO_SUPERUSER_USERNAME', 'admin')
      p = os.environ.get('DJANGO_SUPERUSER_PASSWORD', '')
      e = os.environ.get('DJANGO_SUPERUSER_EMAIL', '')

      print(f'SUPERUSER: username={u!r} email={e!r} password_set={bool(p)}')

      if not p:
          print('SUPERUSER: SKIP — DJANGO_SUPERUSER_PASSWORD not set')
          sys.exit(0)

      if U.objects.filter(username=u).exists():
          print(f'SUPERUSER: SKIP — {u!r} already exists in this database')
          sys.exit(0)

      try:
          U.objects.create_superuser(u, e, p)
          print(f'SUPERUSER: CREATED — {u!r}')
      except Exception as exc:
          print(f'SUPERUSER: FAILED — {exc}')
          sys.exit(1)

container_commands:
  01_migrate:
    command: "source /opt/elasticbeanstalk/deployment/env && source /var/app/venv/*/bin/activate && python manage.py migrate --noinput"
    leader_only: true
  02_collectstatic:
    command: "source /opt/elasticbeanstalk/deployment/env && source /var/app/venv/*/bin/activate && python manage.py collectstatic --noinput"
  03_createsuperuser:
    command: "source /opt/elasticbeanstalk/deployment/env && source /var/app/venv/*/bin/activate && python /opt/deploy_setup.py"
    leader_only: true
