packages:
  yum:
    python3-devel: []
    mariadb105-devel: []
    libjpeg-turbo-devel: []

option_settings:
  aws:elasticbeanstalk:container:python:
    WSGIPath: Attendance_System.wsgi:application
  aws:elasticbeanstalk:environment:proxy:staticfiles:
    /static: staticfiles
  aws:elasticbeanstalk:application:environment:
    DJANGO_SETTINGS_MODULE: Attendance_System.settings

files:
  "/opt/create_superuser.py":
    mode: "000755"
    owner: root
    group: root
    content: |
      import os
      import django
      os.environ.setdefault('DJANGO_SETTINGS_MODULE', 'Attendance_System.settings')
      django.setup()
      from django.contrib.auth import get_user_model
      U = get_user_model()
      u = os.environ.get('DJANGO_SUPERUSER_USERNAME', 'admin')
      e = os.environ.get('DJANGO_SUPERUSER_EMAIL', '')
      p = os.environ.get('DJANGO_SUPERUSER_PASSWORD', '')
      if not p:
          print('SUPERUSER_SKIP: DJANGO_SUPERUSER_PASSWORD not set')
      elif U.objects.filter(username=u).exists():
          print('SUPERUSER_SKIP: {} already exists'.format(u))
      else:
          U.objects.create_superuser(u, e, p)
          print('SUPERUSER_CREATED: {}'.format(u))

container_commands:
  01_migrate:
    command: "source /opt/elasticbeanstalk/deployment/env && source /var/app/venv/*/bin/activate && python manage.py migrate --noinput"
    leader_only: true
  02_collectstatic:
    command: "source /opt/elasticbeanstalk/deployment/env && source /var/app/venv/*/bin/activate && python manage.py collectstatic --noinput"
  03_createsuperuser:
    command: "source /opt/elasticbeanstalk/deployment/env && source /var/app/venv/*/bin/activate && cd /var/app/staging && python /opt/create_superuser.py"
    leader_only: true
